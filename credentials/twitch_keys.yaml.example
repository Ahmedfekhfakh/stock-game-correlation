# Twitch API Credentials — Template
#
# Instructions:
#   1. Go to https://dev.twitch.tv/console
#   2. Log in with your Twitch account
#   3. Click "Register Your Application"
#   4. Fill in:
#        Name:           DataLakePipeline (or any name)
#        OAuth Redirect: http://localhost
#        Category:       Analytics Tool
#   5. Click "Create"
#   6. Click "Manage" on your app → copy the Client ID
#   7. Click "New Secret" → copy the Client Secret
#   8. Save this file as:  credentials/twitch_keys.yaml  (without .example)
#
# IMPORTANT: Never commit credentials/twitch_keys.yaml to git!
#            It is already listed in .gitignore.

client_id: "YOUR_TWITCH_CLIENT_ID_HERE"
client_secret: "YOUR_TWITCH_CLIENT_SECRET_HERE"
